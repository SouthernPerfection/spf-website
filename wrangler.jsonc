{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "spf-website",
  "compatibility_date": "2025-01-01",
  "main": "worker.js",
  "assets": {
    "directory": "./",
    "binding": "ASSETS",
    "run_worker_first": true,
    "not_found_handling": "404-page"
  },
  "kv_namespaces": [
    { "binding": "DRIPS", "id": "9c3eb188d67b492894b681227920c4f0" }
  ],
  "triggers": {
    "crons": ["0 14 * * *"]
  }
}
